{
  "name": "@alexgenovese/mcp-arxiv",
  "version": "1.0.0",
  "description": "MCP Server for accessing arXiv API - papers, search, and metadata",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-arxiv": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "publish": "npm publish",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "arxiv",
    "papers",
    "model-context-protocol",
    "ai-assistant",
    "research",
    "machine-learning"
  ],
  "author": "Alex Geno",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexgenovese/mcp-arxiv"
  },
  "homepage": "https://github.com/alexgenovese/mcp-arxiv#readme",
  "bugs": {
    "url": "https://github.com/alexgenovese/mcp-arxiv/issues"
  },
  "workspaces": [],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.2",
    "fast-xml-parser": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
