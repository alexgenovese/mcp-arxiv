{
  "serverInfo": {
    "name": "arxiv-api",
    "version": "1.0.0"
  },
  "tools": [
    {
      "name": "arxiv_search",
      "description": "Search arXiv for papers matching the query text",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "The search query string" },
          "start": { "type": "number", "description": "Offset for pagination (default: 1)" },
          "max_results": { "type": "number", "description": "Maximum number of results (default: 10, max: 20)" },
          "sort_by": { "type": "string", "description": "Sort by field", "enum": ["submittedDate", "lastUpdatedDate", "relevance", "timestamp"] },
          "sort_order": { "type": "string", "description": "Sort order", "enum": ["descending", "ascending"] },
          "search_field": { "type": "string", "description": "Field to search in", "enum": ["all_text", "titles", "abstracts", "author"] },
          "date_from": { "type": "string", "description": "Start date for date range filter (ISO format)" },
          "date_to": { "type": "string", "description": "End date for date range filter (ISO format)" },
          "category": { "type": "string", "description": "Restrict to a specific category (e.g., cs.LG, quant-ph)" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "arxiv_get_paper",
      "description": "Get full metadata for a specific arXiv paper by ID",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paper_id": { "type": "string", "description": "The arXiv paper ID (e.g., 2401.12345)" }
        },
        "required": ["paper_id"]
      }
    },
    {
      "name": "arxiv_get_pdf_url",
      "description": "Get the canonical absolute and PDF URLs for a paper",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paper_id": { "type": "string", "description": "The arXiv paper ID (e.g., 2401.12345)" }
        },
        "required": ["paper_id"]
      }
    },
    {
      "name": "arxiv_related_papers",
      "description": "Get related papers for a given paper ID",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paper_id": { "type": "string", "description": "The arXiv paper ID" },
          "max_results": { "type": "number", "description": "Maximum related papers to return" }
        },
        "required": ["paper_id"]
      }
    },
    {
      "name": "arxiv_query_authors",
      "description": "Query papers by author name",
      "inputSchema": {
        "type": "object",
        "properties": {
          "author": { "type": "string", "description": "Author name to search for" },
          "max_results": { "type": "number", "description": "Maximum results to return" }
        },
        "required": ["author"]
      }
    },
    {
      "name": "arxiv_get_feed",
      "description": "Get papers from an arXiv RSS/Atom feed by category",
      "inputSchema": {
        "type": "object",
        "properties": {
          "category": { "type": "string", "description": "ArXiv category code (e.g., cs.LG, quant-ph)" },
          "format": { "type": "string", "description": "Feed format (atom or rss, default: atom)", "enum": ["atom", "rss"] },
          "max_results": { "type": "number", "description": "Maximum papers to return" },
          "published_until": { "type": "string", "description": "Filter papers published before this date (ISO format)" }
        },
        "required": ["category"]
      }
    }
  ]
}